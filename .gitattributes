# Normalize line endings to LF on checkin, convert to platform native on checkout
* text=auto eol=lf

# Explicitly binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Lock files — don't touch
package-lock.json -diff
